# myMeal configuration — EXAMPLE ONLY.
#
# Copy to .env and edit. Every value here is a placeholder: this file
# contains NO usable secrets and is safe to commit.
#
# Generated by tools/gen_config_docs.py from the settings inventory.
# Do not edit by hand — CI regenerates and diffs it.
#
# Full reference, including security impact: docs/configuration.md

# --- Storage -------------------------------------------------------
# Directory for the SQLite database and uploaded images.
#MYMEAL_DATA_DIR=./data

# Full SQLAlchemy URL. Blank = SQLite inside DATA_DIR. Only SQLite is
# tested/supported today.
#MYMEAL_DATABASE_URL=

# --- Security ------------------------------------------------------
# JWT signing key. Blank = generated once and persisted in DATA_DIR.
# SECRET. Also supported: MYMEAL_SECRET_KEY_FILE=/run/secrets/... (Docker secrets)
#MYMEAL_SECRET_KEY=

# How long an issued token stays valid, in hours.
#MYMEAL_JWT_HOURS=168

# Bind every request to a single local user. ONLY safe behind an
# authenticating proxy such as Home Assistant ingress.
#MYMEAL_DISABLE_AUTH=false

# Allow anyone who can reach the app to create an account.
#MYMEAL_ALLOW_REGISTRATION=true

# --- Network & proxy -----------------------------------------------
# HTTP port for the app.
#MYMEAL_PORT=7850

# Comma-separated origins allowed to make credentialed cross-origin
# requests. Empty = same-origin only (correct for normal deployments).
#MYMEAL_CORS_ORIGINS=

# How many reverse proxies sit in front. 0 = do not trust X-Forwarded-*
# headers at all.
#MYMEAL_TRUSTED_PROXY_COUNT=0

# --- AI providers --------------------------------------------------
# Which AI backend to use. Blank disables AI features cleanly.
#MYMEAL_AI_PROVIDER=

# API key for the claude provider.
# SECRET. Also supported: MYMEAL_ANTHROPIC_API_KEY_FILE=/run/secrets/... (Docker secrets)
#MYMEAL_ANTHROPIC_API_KEY=

# Model for the claude provider.
#MYMEAL_CLAUDE_MODEL=claude-opus-4-8

# API key for the openai provider.
# SECRET. Also supported: MYMEAL_OPENAI_API_KEY_FILE=/run/secrets/... (Docker secrets)
#MYMEAL_OPENAI_API_KEY=

# Model for the openai provider.
#MYMEAL_OPENAI_MODEL=gpt-4o-mini

# Override the OpenAI API base URL (for compatible gateways).
#MYMEAL_OPENAI_BASE_URL=

# Base URL of the Ollama server. Local, so no API key is needed.
#MYMEAL_OLLAMA_HOST=http://localhost:11434

# Model for the ollama provider.
#MYMEAL_OLLAMA_MODEL=llama3.1

# Per-request timeout for AI provider calls.
#MYMEAL_AI_TIMEOUT_SECONDS=60

# --- MCP (Home Assistant Assist) -----------------------------------
# Run the MCP server so Home Assistant Assist can use myMeal as a tool.
#MYMEAL_MCP_ENABLED=true

# Bind address for the MCP server.
#MYMEAL_MCP_HOST=0.0.0.0

# Port for the MCP server (SSE).
#MYMEAL_MCP_PORT=7851

# Backend API URL the MCP server calls. Blank = derived from PORT.
#MYMEAL_MCP_API=

# Token the MCP server uses when app auth is enabled.
# SECRET. Also supported: MYMEAL_MCP_API_TOKEN_FILE=/run/secrets/... (Docker secrets)
#MYMEAL_MCP_API_TOKEN=

# Treat a dead MCP process as making the whole app UNREADY.
#MYMEAL_MCP_REQUIRED=false

# --- Serving -------------------------------------------------------
# Gunicorn worker processes. SQLite is single-writer: more workers raises
# write contention, it does not raise write throughput.
#MYMEAL_WORKERS=2

# Gunicorn threads per worker.
#MYMEAL_THREADS=4

# Gunicorn worker timeout (seconds).
#MYMEAL_TIMEOUT=120

# Seconds to finish in-flight requests on shutdown.
#MYMEAL_GRACEFUL_TIMEOUT=30

# Maximum upload size in MB.
#MYMEAL_MAX_UPLOAD_MB=50

# Timeout for outbound HTTP (recipe import).
#MYMEAL_HTTP_TIMEOUT_SECONDS=20

# Maximum bytes read from a page during recipe import.
#MYMEAL_MAX_IMPORT_BYTES=5242880

# --- Misc ----------------------------------------------------------
# Path to the built SPA. Blank = the location baked into the image.
#MYMEAL_FRONTEND_DIST=

# Application log level.
#MYMEAL_LOG_LEVEL=INFO

# Flask debug mode. NEVER enable in production — it exposes an interactive
# debugger that executes arbitrary code.
#MYMEAL_DEBUG=false
